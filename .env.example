# ============================================
# 环境配置模板
# ============================================
# 每个环境文件包含完整配置，启动时自动复制到 .env：
#   .env.local.env       → 本地 MySQL      (pnpm dev)
#   .env.development.env → 远程 dev 库      (pnpm dev:dev)
#   .env.production.env  → 远程 prod 库     (pnpm dev:prod / pnpm build)
#
# 也可以手动切换: pnpm env:use <local|development|production>
# ============================================

# 数据库
DATABASE_URL=mysql://root:your_password@127.0.0.1:3306/your_database
DB_TABLE_PREFIX=nca_

# JWT
JWT_SECRET=your_jwt_secret

# AI
AI_API_KEY=your_api_key
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_MODEL=qwen-plus
